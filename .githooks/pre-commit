#!/bin/sh
# Standard pre-commit hook for apps-in-toss-community sub-repos.
# Activated per-clone via: git config core.hooksPath .githooks
#
# Runs biome on staged files. Fails the commit if lint/format issues exist.
# CI runs the same `pnpm lint` as the actual enforcement layer; this hook
# is a fast feedback mechanism so issues are caught before push.

set -e

# Collect staged files matching biome's targets (TS/JS/JSON/etc.)
staged=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|json|jsonc)$' || true)

if [ -z "$staged" ]; then
  exit 0
fi

# Run biome check on staged files. `--no-errors-on-unmatched` so files
# excluded by biome.json `files.includes` (e.g., dist/, node_modules/)
# don't fail the hook.
echo "$staged" | xargs pnpm exec biome check --no-errors-on-unmatched
