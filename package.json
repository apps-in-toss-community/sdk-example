    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@ait-co/devtools": "^0.0.2",
    "@apps-in-toss/web-framework": "^2.4.5",
    "qrcode": "^1.5.4",
