{
  "name": "sdk-example",
  "private": true,
  "version": "0.1.0",
  "description": "Community-built interactive reference app for the @apps-in-toss/web-framework SDK.",
  "author": "apps-in-toss-community",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "dev:phone": "AIT_TUNNEL=1 vite",
    "prebuild": "tsx scripts/build-og-images.tsx",
    "build": "tsc -b && vite build && tsx scripts/build-route-html.ts && tsx scripts/build-sitemap.ts",
    "build:og": "tsx scripts/build-og-images.tsx",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "bundle:ait": "ait build",
    "bundle:ait:dogfood": "RELEASE_CHANNEL=dogfood ait build",
    "scaffold:domain": "node scripts/scaffold-domain.ts",
    "sync:readme": "tsx scripts/sync-readme-domains.ts",
    "sync:readme:check": "tsx scripts/sync-readme-domains.ts --check"
  },
  "dependencies": {
    "@ait-co/devtools": "^0.1.30",
    "@ait-co/polyfill": "^0.1.8",
    "@apps-in-toss/web-framework": "^2.6.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@apps-in-toss/cli": "2.5.2",
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
