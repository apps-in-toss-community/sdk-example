# Base URL of an oidc-bridge instance for the AuthPage OIDC demo section.
# Leave unset to disable the demo (the section will render an info card with
# setup instructions instead). When set, the AuthPage OIDC bridge demo posts
# `appLogin()`'s authorizationCode to `<VITE_OIDC_BRIDGE_URL>/verify`.
#
# A community-operated public instance is planned but not yet deployed; for
# now point this at a self-host. See the bridge repo for a quickstart:
#   https://github.com/apps-in-toss-community/oidc-bridge
#
# Examples:
#   VITE_OIDC_BRIDGE_URL=http://localhost:8080
#   VITE_OIDC_BRIDGE_URL=https://oidc-bridge.example.com
VITE_OIDC_BRIDGE_URL=
